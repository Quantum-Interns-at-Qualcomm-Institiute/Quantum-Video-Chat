@startuml video-pipeline
!theme plain
skinparam backgroundColor transparent
skinparam defaultFontName "Segoe UI, Helvetica, Arial, sans-serif"
skinparam defaultFontSize 12
skinparam shadowing false
skinparam ActivityBarColor #495057
skinparam ActivityBorderColor #ADB5BD
skinparam ActivityBackgroundColor #F8F9FA

skinparam activity {
    BackgroundColor #F8F9FA
    BorderColor #ADB5BD
    FontColor #212529
    DiamondBackgroundColor #FFF3CD
    DiamondBorderColor #FFECB5
}

title Video Frame Pipeline

|#E8F4FD|Sender|
start
:OpenCV capture\n(or debug random frame);
:H.264 encode\n(ffmpeg, ultrafast/zerolatency);
:AES-128 encrypt\n(prepend 4-byte key_index);

|#F0FFF0|Network|
:WebSocket /video\n(Socket.IO binary);
:Server broadcast\n(exclude sender);

|#FFF0F0|Receiver|
:Read 4-byte key_index;
if (key_index matches\ncurrent key?) then (yes)
    :AES-128 decrypt;
    :H.264 decode\n(ffmpeg rawvideo);
    :IPC 'frame' event\n(Electron → Renderer);
    :Canvas drawImage();
else (no)
    :Drop frame\n(stale key);
endif
stop

@enduml
