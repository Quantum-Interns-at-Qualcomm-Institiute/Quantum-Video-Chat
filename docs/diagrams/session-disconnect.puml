@startuml session-disconnect
!theme plain
skinparam backgroundColor transparent
skinparam defaultFontName "Segoe UI, Helvetica, Arial, sans-serif"
skinparam defaultFontSize 12
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

skinparam participant {
    BackgroundColor #F8F9FA
    BorderColor #ADB5BD
    FontColor #212529
}

skinparam sequence {
    ArrowColor #495057
    LifeLineBorderColor #CED4DA
    LifeLineBackgroundColor #F8F9FA
    DividerBackgroundColor #E9ECEF
    GroupBackgroundColor #F8F9FA
}

title Session Disconnect Flow

participant "Initiator\n(Electron)" as init
participant "Initiator\nMiddleware" as initmw
participant "Backend\nServer" as server
participant "Peer\nMiddleware" as peermw
participant "Peer\n(Electron)" as peer

init -> initmw : disconnect()\nvia IPC
activate initmw

initmw -> initmw : stop key rotation\n(_key_stop.set())
initmw -> initmw : SocketClient.disconnect()

initmw -> server : POST /disconnect_peer\n{user_id}
activate server

server -> server : set user → IDLE\nset peer → IDLE

server -> peermw : POST /peer_disconnected\n{peer_id}
activate peermw
peermw -> peermw : stop key rotation
peermw -> peermw : SocketClient.disconnect()
peermw -> peer : status: peer_disconnected
peermw --> server : 200 OK
deactivate peermw

server --> initmw : 200 OK
deactivate server

initmw -> init : status: peer_disconnected
deactivate initmw

note over init, peer
  Both clients return to LIVE state,
  ready for a new call.
end note

@enduml
